{
  "version": 2,
  "installCommand": "pnpm install",
  "buildCommand": "pnpm run typecheck:libs && pnpm --filter @workspace/tradescope run build",
  "outputDirectory": "artifacts/tradescope/dist/public",
  "framework": null,
  "functions": {
    "api/index.ts": {
      "maxDuration": 30,
      "memory": 512
    }
  },
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/index.ts" },
    { "source": "/:path*", "destination": "/index.html" }
  ],
  "env": {
    "BASE_PATH": "/"
  }
}
