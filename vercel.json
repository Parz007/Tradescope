{
  "version": 2,
  "installCommand": "npx pnpm@9.15.4 install",
  "buildCommand": "pnpm run typecheck:libs && pnpm --filter @workspace/tradescope run build && pnpm --filter @workspace/api-server run build",
  "outputDirectory": "artifacts/tradescope/dist/public",
  "framework": null,
  "functions": {
    "api/index.js": {
      "maxDuration": 30,
      "memory": 512,
      "includeFiles": "artifacts/api-server/dist/**"
    }
  },
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/index.js" },
    { "source": "/:path*", "destination": "/index.html" }
  ],
  "env": {
    "BASE_PATH": "/"
  }
}
